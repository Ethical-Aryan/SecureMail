# Flask Settings
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=super-secret-session-key-change-in-production

# JWT Settings
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# Database Settings
DB_TYPE=mysql

# MySQL Settings (XAMPP Defaults)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=securemail
